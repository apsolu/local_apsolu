{{!
    @template local_apsolu/payment_validation

    Template Moodle pour afficher la page de paiement.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * payment_centers
    * count_payment_centers
    * payment_centers

    Example context (json):
    {
        "payment_centers": [],
        "count_payment_centers": 0,
        "payment_centers": []
    }
}}
<div class="container-fluid">
    <div class="row justify-content-center">
        {{^payment_centers}}
            <div class="alert alert-info">
                <p>{{#str}}no_courses, local_apsolu{{/str}}</p>
                {{#is_siuaps_rennes}}
                    <p>{{#str}}no_courses_complements, local_apsolu{{/str}}</p>
                {{/is_siuaps_rennes}}
            </div>
        {{/payment_centers}}

        {{#count_payment_centers}}
            {{#str}}warning_payment, local_apsolu, {{{functional_contact}}}{{/str}}
        {{/count_payment_centers}}

        {{#payment_centers}}
        <div class="col">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4">
                    <h1 class="apsolu-payment-h1 text-center h4 mb-4 fw-bold">{{name}}</h1>
                    <form method="post" action="{{ action_url }}" class="apsolu-payment-forms">

                        <!-- LISTE DES ÉLÉMENTS -->
                        {{#count_cards}}
                            <div class="apsolu-payment-section-div mb-3">
                                {{#cards}}
                                    <div class="clearfix apsolu-payment-section-head-div d-flex align-items-start mb-2">
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">{{name}}</div>
                                            <div class="apsolu-payment-section-comment-div text-muted small">{{summary}}</div>
                                        </div>
                                        <div class="text-end fw-semibold ms-3" style="min-width: 90px;">
                                            {{price_format}} €
                                        </div>
                                    </div>
                                {{/cards}}
                            </div>
                        {{/count_cards}}


                        <!-- TOTAL -->
                        <div class="apsolu-payment-section-div border-top pt-3 mt-3">
                            <div class="clearfix d-flex d-flex mb-2">
                                <span class="apsolu-payment-details flex-grow-1 fw-bold">Montant total</span>
                                <span class="apsolu-payment-details text-end" style="min-width: 90px;">{{total_amount_format}} €</span>
                            </div>

                            {{#atout_deduction_raw}}
                                <div class="clearfix d-flex align-items-center mt-4">
                                    <span class="apsolu-payment-details flex-grow-1 fw-bold">Réduction Atouts Normandie</span>
                                    <span class="apsolu-payment-details text-end" style="min-width: 90px;">- {{atout_deduction_format}} €</span>
                                </div>
                            {{/atout_deduction_raw}}

                            <div class="clearfix d-flex d-flex mt-4 mb-4">
                                <span class="apsolu-payment-details flex-grow-1 fw-bold">Montant payé</span>
                                <span class="apsolu-payment-details text-end" style="min-width: 90px;">{{paid_amount_format}} €</span>
                            </div>

                            <div class="border-top pt-1 mt-1">
                                <div class="clearfix d-flex align-items-center fs-5 fw-bold mt-3">
                                    <span class="apsolu-payment-details flex-grow-1">Reste à payer</span>
                                    <span class="apsolu-payment-details text-end" style="min-width: 90px;"><strong>{{remaining_for_paybox}} €</strong></span>
                                </div>
                            </div>
                        </div>

                        <!-- ACTIONS -->
                        <div class="payment-actions mt-4">
                            {{^is_fully_paid_by_atouts}}
                                {{#is_atouts_enabled}}
                                    {{^atout_deduction_raw}}
                                        <!-- Bouton pour AJOUTER une réduction -->
                                        <button type="button"
                                                class="btn btn-outline-info w-100 mb-3 atouts-trigger"
                                                data-paymentid="{{payment_id}}">
                                            <i class="fa fa-qrcode me-2"></i>
                                            Utiliser mon avantage Atouts Normandie
                                        </button>
                                    {{/atout_deduction_raw}}

                                    {{#atout_deduction_raw}}
                                        <!-- Bouton pour ANNULER la réduction existante -->
                                        <button type="button" class="btn btn-outline-danger w-100 mb-3 atouts-cancel" data-paymentid="{{payment_id}}">
                                            <i class="fa fa-times me-2"></i> Annuler ma réduction Atouts Normandie
                                        </button>
                                    {{/atout_deduction_raw}}
                                {{/is_atouts_enabled}}

                                <!-- Formulaire PAYBOX -->

                                <div class="text-center">
                                    <input type="hidden" name="PBX_SITE" value="{{paybox.PBX_SITE}}"/>
                                    <input type="hidden" name="PBX_RANG" value="{{paybox.PBX_RANG}}"/>
                                    <input type="hidden" name="PBX_IDENTIFIANT" value="{{paybox.PBX_IDENTIFIANT}}"/>
                                    <input type="hidden" name="PBX_TOTAL" value="{{paybox.PBX_TOTAL}}"/>
                                    <input type="hidden" name="PBX_DEVISE" value="{{paybox.PBX_DEVISE}}"/>
                                    <input type="hidden" name="PBX_CMD" value="{{paybox.PBX_CMD}}"/>
                                    <input type="hidden" name="PBX_PORTEUR" value="{{paybox.PBX_PORTEUR}}"/>
                                    <input type="hidden" name="PBX_RETOUR" value="{{paybox.PBX_RETOUR}}"/>
                                    <input type="hidden" name="PBX_HASH" value="{{paybox.PBX_HASH}}"/>
                                    <input type="hidden" name="PBX_TIME" value="{{paybox.PBX_TIME}}"/>
                                    <input type="hidden" name="PBX_EFFECTUE" value="{{paybox.PBX_EFFECTUE}}"/>
                                    <input type="hidden" name="PBX_REFUSE" value="{{paybox.PBX_REFUSE}}"/>
                                    <input type="hidden" name="PBX_ANNULE" value="{{paybox.PBX_ANNULE}}"/>
                                    <input type="hidden" name="PBX_ATTENTE" value="{{paybox.PBX_ATTENTE}}"/>
                                    <input type="hidden" name="PBX_REPONDRE_A" value="{{paybox.PBX_REPONDRE_A}}"/>
                                    <input type="hidden" name="PBX_TYPEPAIEMENT" value="{{paybox.PBX_TYPEPAIEMENT}}"/>
                                    <input type="hidden" name="PBX_TYPECARTE" value="{{paybox.PBX_TYPECARTE}}"/>
                                    <input type="hidden" name="PBX_SHOPPINGCART" value="{{paybox.PBX_SHOPPINGCART}}"/>
                                    <input type="hidden" name="PBX_BILLING" value="{{{paybox.PBX_BILLING}}}"/>
                                    <input type="hidden" name="PBX_HMAC" value="{{paybox.PBX_HMAC}}"/>

                                    <button class="btn btn-primary btn-lg w-100" type="submit">
                                        <i class="fa fa-credit-card me-2"></i> Payer {{remaining_for_paybox}} €
                                    </button>
                                </div>
                            {{/is_fully_paid_by_atouts}}

                            {{#is_fully_paid_by_atouts}}
                                <div class="alert alert-success text-center">
                                    <p class="mb-3">Votre commande va être intégralement réglée par Atouts Normandie.</p>
                                    <a href="{{wwwroot}}/local/apsolu/payment/confirm_full_atouts.php?id={{payment_id}}&sesskey={{sesskey}}"
                                    class="btn btn-success btn-lg w-100">
                                    <i class="fa fa-check-circle me-2"></i> Confirmer ma commande
                                    </a>
                                </div>
                                <button type="button" class="btn btn-outline-danger w-100 mb-3 atouts-cancel" data-paymentid="{{payment_id}}">
                                    <i class="fa fa-times me-2"></i> Annuler ma réduction Atouts Normandie
                                </button>
                            {{/is_fully_paid_by_atouts}}

                        </div>
                    </form>
                </div>
            </div>
        </div>
        {{/payment_centers}}
    </div>
</div>

<!-- Modal Atouts Normandie (Caché par défaut) -->
{{#is_atouts_enabled}}
<div class="modal fade" id="atoutsModal" tabindex="-1" role="dialog" aria-labelledby="atoutsModalLabel" aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered" role="document">

        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="atoutsModalLabel">Atouts Normandie</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <!-- Étape 1 : Champ de saisie du numéro de carte -->
                <div id="atouts_step_1">
                    <p>Veuillez saisir votre numéro de carte Atouts Normandie :</p>
                    <input type="text" id="atouts_nocarte_input"
                           class="form-control form-control-lg text-center font-weight-bold"
                           placeholder="Ex: A1B2C3D4"
                           maxlength="20">
                </div>

                <!-- Étape 2 : Champ de saisie du montant (caché au début) -->
                <div id="atouts_step_2" style="display:none;" class="mt-2">

                    <div class="alert alert-success text-center">
                        Solde disponible sur votre carte : <strong><span
                        id="atouts_display_solde">0.00</span></strong>
                    </div>

                    <div class="form-group">
                        <label for="atouts_amount_to_use">Montant à déduire de votre commande (€) :</label>
                        <input type="number" id="atouts_amount_to_use"
                               class="form-control form-control-lg text-center font-weight-bold" step="0.01"
                               min="0.01">
                    </div>

                </div>

                <div id="atouts_status_area" class="mt-3 text-center">
                    <!-- Les messages d'erreur ou de succès AJAX apparaîtront ici -->
                </div>

            </div>

            <div class="modal-footer">

                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="atouts_check_balance">
                    <i class="fa fa-search"></i> Vérifier mon solde
                </button>
                <button type="button" class="btn btn-success" id="atouts_confirm_deduction"
                        style="display:none;">
                    <i class="fa fa-check"></i> Appliquer la réduction
                </button>

            </div>

        </div>

    </div>

</div>
{{/is_atouts_enabled}}
